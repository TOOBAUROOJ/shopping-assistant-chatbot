<!DOCTYPE html>
<html>

<head>

    <title>Shopping Assistant Bot</title>

</head>

<body>

    <h1>🛍️ Virtual Shopping Assistant</h1>

    <form method="POST">

        <input type="text"
               name="question"
               placeholder="Ask your question"
               required>

        <button type="submit">Ask</button>

    </form>

    {% if response %}

    <h3>Bot Response:</h3>

    <p>{{ response }}</p>

    {% endif %}

</body>

</html>
